<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Base Map Color (Tan/Paper) -->
    <path
        android:fillColor="#E3D7B5"
        android:pathData="M0,0h108v108h-108z" />

    <!-- Terrain / Park (Green) -->
    <path
        android:fillColor="#C6D8A9"
        android:pathData="M -10,30 Q 20,10 40,40 T 80,30 Q 100,60 120,40 L 120,120 L -10,120 Z" />

    <!-- Another Terrain Patch -->
    <path
        android:fillColor="#A9CBA9"
        android:pathData="M 50,-10 Q 70,20 120,10 L 120,-10 Z" />

    <!-- Water / River (Blue) -->
    <path
        android:fillColor="#A1D2E6"
        android:pathData="M -10,70 C 20,80 30,50 60,60 C 90,70 100,40 120,50 L 120,70 C 100,60 90,90 60,80 C 30,70 20,100 -10,90 Z" />

    <!-- Main Road -->
    <path
        android:strokeColor="#F2C94C"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 40,40 L 80,30 L 100,80 L 120,90" />

    <!-- Secondary Roads -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 10,10 L 40,40 L 45,70 L 20,120" />

    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 80,30 L 90,-10" />

    <!-- City grid lines (subtle) -->
    <path
        android:strokeColor="#22000000"
        android:strokeWidth="1"
        android:fillColor="#00000000"
        android:pathData="M 10,20 h 20 M 10,30 h 20 M 20,20 v 20 M 100,20 h 20 M 100,30 h 20 M 110,10 v 20 M 60,90 h 20 M 60,100 h 20 M 70,90 v 20" />

    <!-- Left panel shading -->
    <path
        android:pathData="M 0,0 h 36 v 108 h -36 z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0"
                android:startY="0"
                android:endX="36"
                android:endY="0">
                <item android:offset="0" android:color="#00000000" />
                <item android:offset="1" android:color="#33000000" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Middle panel shading -->
    <path
        android:pathData="M 36,0 h 36 v 108 h -36 z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="36"
                android:startY="0"
                android:endX="72"
                android:endY="0">
                <item android:offset="0" android:color="#33000000" />
                <item android:offset="1" android:color="#33FFFFFF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Right panel shading -->
    <path
        android:pathData="M 72,0 h 36 v 108 h -36 z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="72"
                android:startY="0"
                android:endX="108"
                android:endY="0">
                <item android:offset="0" android:color="#33FFFFFF" />
                <item android:offset="1" android:color="#33000000" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Crease lines to emphasize the folds -->
    <!-- Valley fold -->
    <path
        android:strokeColor="#1A000000"
        android:strokeWidth="1"
        android:pathData="M 36,0 v 108" />
    <!-- Mountain fold -->
    <path
        android:strokeColor="#33FFFFFF"
        android:strokeWidth="1"
        android:pathData="M 72,0 v 108" />

</vector>