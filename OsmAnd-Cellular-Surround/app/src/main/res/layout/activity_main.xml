<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OsmAnd Cellular Surround"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvCredit"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/opencellid_attribution"
        android:textAlignment="center"
        android:textColor="@android:color/holo_blue_dark"
        android:autoLink="web"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvDocs"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/docs_link"
        android:textAlignment="center"
        android:textColor="@android:color/holo_blue_dark"
        android:autoLink="web"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvCredit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilApiKey"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvDocs">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etApiKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:hint="OpenCelliD / UnwiredLabs API Key" />
    </com.google.android.material.textfield.TextInputLayout>

    <Button
        android:id="@+id/btnSaveApiKey"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Save Key"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tilApiKey"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvRadiusLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Scan Radius:"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/btnSaveApiKey"
        app:layout_constraintStart_toStartOf="parent" />

    <Spinner
        android:id="@+id/spinnerRadius"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="@id/tvRadiusLabel"
        app:layout_constraintBottom_toBottomOf="@id/tvRadiusLabel"
        app:layout_constraintStart_toEndOf="@id/tvRadiusLabel"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:id="@+id/scrollViewStatus"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvRadiusLabel"
        app:layout_constraintBottom_toTopOf="@id/llSqlInput"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: Ready\n"
            android:textSize="12sp"
            android:textIsSelectable="true"
            android:typeface="monospace" />
    </ScrollView>

    <LinearLayout
        android:id="@+id/llSqlInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/llButtons">

        <EditText
            android:id="@+id/etSql"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:hint="SQL query (e.g., SELECT * FROM cell_towers LIMIT 10)"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnRunSql"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Run SQL" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/llButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnCopyLog"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Copy Log" />

        <Button
            android:id="@+id/btnScan"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Scan Cell &amp; Show" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
