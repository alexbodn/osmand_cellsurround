<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OsmAnd Cellular Surround"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Home" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CONFIG" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Log" />
    </com.google.android.material.tabs.TabLayout>

    <FrameLayout
        android:id="@+id/flTabContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/tabLayout"
        app:layout_constraintBottom_toTopOf="@id/llButtons">

        <ScrollView
            android:id="@+id/scrollViewBackground"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvCredit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/opencellid_attribution"
                    android:textAlignment="center"
                    android:textColor="@android:color/holo_blue_dark"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/tvOsmAndCredit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/osmand_attribution"
                    android:textAlignment="center"
                    android:textColor="@android:color/holo_blue_dark"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="About OsmAnd Cellular Surround"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="This application serves as an external plugin for OsmAnd, allowing you to visualize your surrounding cellular network towers directly on the map. It intelligently resolves cell tower locations from local databases and OpenCelliD to generate precise GPX files."
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Data Donation"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="By donating data, you help improve the OpenCelliD database, a community-driven project mapping cellular towers worldwide. When you click DONATE, the app securely sends your current, live cellular network info along with highly accurate GPS coordinates.\n\nDonated information is read directly from your device sensors and cannot be spoofed."
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/tvDocumentationLink"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Read OpenCelliD Documentation"
                    android:textColor="@android:color/holo_blue_dark"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvUserProfileLink"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="View your OpenCelliD Profile &amp; History"
                    android:textColor="@android:color/holo_blue_dark"
                    android:layout_marginBottom="16dp" />
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/scrollViewStatus"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <Button
                    android:id="@+id/btnCopyLog"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Copy Log"
                    android:layout_gravity="end"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Status: Ready\n"
                    android:textSize="12sp"
                    android:textIsSelectable="true"
                    android:typeface="monospace" />

                <Button
                    android:id="@+id/btnOsmAndPlugins"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:visibility="gone"
                    android:text="Open OsmAnd Plugins Menu" />
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/scrollViewConfig"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/llSqlContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            <LinearLayout
                android:id="@+id/llRadius"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvRadiusLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Scan Radius:"
                    android:layout_gravity="center_vertical" />

                <Spinner
                    android:id="@+id/spinnerRadius"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_gravity="center_vertical" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvApiKeyLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp" />

            <LinearLayout
                android:id="@+id/llApiKey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilApiKey"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etApiKey"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:textSize="12sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <Button
                    android:id="@+id/btnSaveApiKey"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Save Key"
                    android:layout_marginStart="8dp"
                    android:layout_gravity="center_vertical" />
            </LinearLayout>


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Advanced"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvCellInfoLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="radio,mcc,mnc,lac,cid"
                android:textSize="12sp"
                android:layout_marginTop="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etCellInfo"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:hint="e.g. lte,310,410,12345,67890"
                    android:inputType="text" />

                <Button
                    android:id="@+id/btnReloadCellInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reload"
                    android:layout_gravity="center_vertical" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Towers SQL"
                android:textSize="12sp"
                android:layout_marginTop="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etTowersSql"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:minLines="3"
                    android:maxLines="5"
                    android:scrollbars="vertical"
                    android:gravity="top|start"
                    android:inputType="textMultiLine"
                    android:hint="SQL to select towers for map"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <Button
                        android:id="@+id/btnDefaultTowersSql"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Default" />

                    <Button
                        android:id="@+id/btnSaveTowersSql"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Save" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SQL Console"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/llSqlInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etSql"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="200dp"
                    android:gravity="top|start"
                    android:inputType="textMultiLine"
                    android:minLines="5"
                    android:scrollbars="vertical"
                    android:hint="SQL query (e.g., SELECT * FROM cell_towers LIMIT 10)"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp"
                    android:gravity="center_horizontal">

                    <Button
                        android:id="@+id/btnOpenFile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Open File" />

                    <Button
                        android:id="@+id/btnRunFile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Run File" />

                    <Button
                        android:id="@+id/btnRunSql"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Run SQL" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Result:"
                    android:layout_gravity="center_vertical"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnCopySqlResult"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Copy" />
            </LinearLayout>

            <ScrollView
                android:id="@+id/scrollViewSqlResult"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/tvSqlResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textIsSelectable="true"
                    android:typeface="monospace" />
            </ScrollView>
        </LinearLayout>
        </ScrollView>


    </FrameLayout>

    <LinearLayout
        android:id="@+id/llButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnDonate"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="DONATE DATA" />

        <Button
            android:id="@+id/btnScan"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="SHOW ON MAP" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
